DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_ALLOWED_HOSTS=shop.tg11.org
DJANGO_CSRF_TRUSTED_ORIGINS=https://shop.tg11.org
DJANGO_TIME_ZONE=America/New_York
DJANGO_LOG_LEVEL=INFO
SITE_URL=https://shop.tg11.org
SERVE_MEDIA=1

APP_HOST=127.6.0.10
APP_PORT=8000
GUNICORN_BIND=127.6.0.10:8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

DB_ENGINE=django.db.backends.postgresql
DB_HOST=127.6.0.11
DB_PORT=55432
POSTGRES_DB=tg11_shop
POSTGRES_USER=tg11_shop
POSTGRES_PASSWORD=change-this-now
DB_CONN_MAX_AGE=60

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=TG11 Shop <no-reply@shop.tg11.org>
SERVER_EMAIL=TG11 Shop <server@shop.tg11.org>
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=0
EMAIL_USE_SSL=0
FULFILLMENT_EMAIL_RECIPIENTS=orders@shop.tg11.org

SENTRY_DSN=https://public_key@o0000000000000000.ingest.us.sentry.io/0000000000000000
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=git-######-replace-me
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=0

# Stripe account ID is safe to commit; API keys and webhook secrets are not.
STRIPE_ACCOUNT_ID=acct_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CURRENCY=usd
ENABLE_PROMOTIONS=1
ENABLE_SHIPPING_ENGINE=1
ENABLE_LIVE_SHIPPING_RATES=0
ENABLE_SHIPPING_FALLBACK_RATES=1
INCLUDE_FALLBACK_WITH_LIVE_RATES=0
ENABLE_EMERGENCY_SHIPPING_FALLBACK=1
EMERGENCY_DOMESTIC_SHIPPING_AMOUNT=6.95
EMERGENCY_INTERNATIONAL_SHIPPING_AMOUNT=24.95
SHIPPING_RATE_PROVIDER=rules
SHIPPING_PROVIDER_TIMEOUT_SECONDS=8
LIVE_SHIPPING_DEFAULT_DAYS=5
EASYPOST_API_KEY=
EASYPOST_API_URL=https://api.easypost.com/v2
EASYPOST_TRACKING_URL=https://your-easypost-tracking-host/track/
EASYPOST_WEBHOOK_URL=https://your-easypost-webhook-host/easypost
EASYPOST_WEBHOOK_SECRET=replace_me
SHIPPO_API_TOKEN=
SHIPPO_API_URL=https://api.goshippo.com
SHIPPO_WEBHOOK_URL=https://shop.tg11.org/webhooks/shippo/
SHIPPO_WEBHOOK_SECRET=
SHIP_FROM_NAME=TG11 Shop
SHIP_FROM_COMPANY=TG11 LLC
SHIP_FROM_LINE1=
SHIP_FROM_LINE2=
SHIP_FROM_CITY=
SHIP_FROM_STATE=
SHIP_FROM_POSTAL_CODE=
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=
SHIP_FROM_EMAIL=server@shop.tg11.org
TAX_PROVIDER=none
TAX_PROVIDER_REQUIRED=0
STRIPE_TAX_ENABLED=0
STRIPE_TAX_BEHAVIOR=exclusive
PRICING_ALERT_EMAILS_ENABLED=0
REQUIRED_ENV_KEYS=SITE_URL,STRIPE_SECRET_KEY,STRIPE_PUBLISHABLE_KEY,STRIPE_WEBHOOK_SECRET,DEFAULT_FROM_EMAIL,EMAIL_BACKEND

POPCUSTOMS_API_KEY=popcustoms_api_key_replace_me
POPCUSTOMS_ORDERS_ENDPOINT=https://i.popcustoms.com/stores/your-store-id/webhooks/orders?platform=General
POPCUSTOMS_LISTINGS_ENDPOINT=
POPCUSTOMS_INVENTORY_ENDPOINT=
POPCUSTOMS_API_HEADER=X-API-Key
POPCUSTOMS_API_VALUE_PREFIX=

ETSY_API_KEY=etsy_keystring_replace_me
ETSY_SHARED_SECRET=etsy_shared_secret_replace_me

SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=0
