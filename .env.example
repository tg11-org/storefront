DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_ALLOWED_HOSTS=shop.tg11.org
DJANGO_CSRF_TRUSTED_ORIGINS=https://shop.tg11.org
DJANGO_TIME_ZONE=America/New_York
DJANGO_LOG_LEVEL=INFO
SITE_URL=https://shop.tg11.org
SERVE_MEDIA=1

APP_HOST=127.6.0.10
APP_PORT=8000
GUNICORN_BIND=127.6.0.10:8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

DB_ENGINE=django.db.backends.postgresql
DB_HOST=127.6.0.11
DB_PORT=55432
POSTGRES_DB=tg11_shop
POSTGRES_USER=tg11_shop
POSTGRES_PASSWORD=change-this-now
DB_CONN_MAX_AGE=60

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=TG11 Shop <no-reply@shop.tg11.org>
SERVER_EMAIL=TG11 Shop <server@shop.tg11.org>
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=0
EMAIL_USE_SSL=0

# Stripe account ID is safe to commit; API keys and webhook secrets are not.
STRIPE_ACCOUNT_ID=acct_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CURRENCY=usd

POPCUSTOMS_API_KEY=popcustoms_api_key_replace_me
POPCUSTOMS_ORDERS_ENDPOINT=https://i.popcustoms.com/stores/your-store-id/webhooks/orders?platform=General
POPCUSTOMS_API_HEADER=X-API-Key
POPCUSTOMS_API_VALUE_PREFIX=

SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=0
